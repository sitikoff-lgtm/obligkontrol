// ВСПОМОГАТЕЛЬНАЯ ФУНКЦИЯ: ПРОВЕРКА ФОРМАТА ISIN
// ============================================================================

/**
 * Проверяет, соответствует ли строка формату ISIN
 * ISIN = 2 буквы + 9 букв/цифр + 1 контрольная цифра
 * @param {string} isin - Строка для проверки
 * @return {boolean} true - если формат правильный
 */
function isValidIsinFormat(isin) {
  if (!isin || typeof isin !== 'string') return false;
  
  var cleanIsin = isin.trim().toUpperCase();
  
  // ISIN должен быть длиной 12 символов
  if (cleanIsin.length !== 12) return false;
  
  // Первые 2 символа должны быть буквами (RU, SU, US, XS и т.д.)
  var firstTwo = cleanIsin.substring(0, 2);
  if (!firstTwo.match(/^[A-Z]{2}$/)) return false;
  
  // Остальные 10 символов должны быть буквами или цифрами
  var rest = cleanIsin.substring(2);
  if (!rest.match(/^[A-Z0-9]{10}$/)) return false;
  
  return true;
}


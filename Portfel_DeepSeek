// БЛОК 2. ЗАГРУЗЧИК ДАННЫХ MOEX (РАБОТАЕТ С БИРЖЕВЫМИ БУМАГАМИ)
// ============================================================================

function fetchAllMoexDataBatch() {
  var moexCache = {};
  
  // ТОЛЬКО БИРЖЕВЫЕ БУМАГИ (внебиржевые исключены, например RU000A10FDE3)
  var allIsins = [
    "RU000A108P46", "RU000A107RZ0", "RU000A10BPZ1", "RU000A1061K1",
    "SU26244RMFS2", "SU26240RMFS0", "SU26233RMFS5", "SU26230RMFS1",
    "RU000A106UW3", "RU000A1077X0", "RU000A107XA1", "RU000A1098F3",
    "RU000A10EYJ1", "RU000A10CC99", "RU000A10DZW3", "RU000A10DSG1",
    "RU000A107UU5"
  ];
  
  writeToLogSheet("ИНФО", "Загрузка " + allIsins.length + " биржевых бумаг с MOEX...", 0);
  
  var successCount = 0;
  var notFoundCount = 0;
  var errorCount = 0;
  
  for (var i = 0; i < allIsins.length; i++) {
    var isin = allIsins[i];
    
    // ПРАВИЛЬНЫЙ URL (работает как в успешном тесте)
    var url = "https://moex.com/iss/securities.json?q=" + isin + "&iss.meta=off&iss.only=securities,marketdata";
    
    try {
      // Задержка между запросами (важно для MOEX)
      if (i > 0) Utilities.sleep(300);
      
      var response = UrlFetchApp.fetch(url, {
        muteHttpExceptions: true,
        headers: {
          'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
          'Accept': 'application/json'
        }
      });
      
      // Проверяем статус ответа
      if (response.getResponseCode() !== 200) {
        writeToLogSheet("ПРЕДУПРЕЖДЕНИЕ", isin + " → код " + response.getResponseCode(), 0);
        errorCount++;
        continue;
      }
      
      var json = JSON.parse(response.getContentText());
      
      // Проверяем, есть ли данные
      if (!json || !json.securities || !json.securities.data || json.securities.data.length === 0) {
        writeToLogSheet("ПРЕДУПРЕЖДЕНИЕ", isin + " → не найден на MOEX", 0);
        notFoundCount++;
        continue;
      }
      
      // ============================================================
      // ПАРСИМ ДАННЫЕ ИЗ securities
      // ============================================================
      var sCols = json.securities.columns;
      var sRow = json.securities.data[0];
      
      // Находим ISIN
      var isinIdx = sCols.indexOf("isin");
      if (isinIdx === -1) isinIdx = sCols.indexOf("secid");
      var actualIsin = String(sRow[isinIdx]).trim().toUpperCase();
      
      // Базовая структура
      moexCache[actualIsin] = {
        price: 0,
        nkd: 0,
        faceValue: 1000,
        maturity: "",
        couponValue: 0,
        period: 2
      };
      
      // ============================================================
      // ПАРСИМ ДАННЫЕ ИЗ marketdata (ЦЕНА И НКД)
      // ============================================================
      if (json.marketdata && json.marketdata.data && json.marketdata.data.length > 0) {
        var mCols = json.marketdata.columns;
        var mRow = json.marketdata.data[0];
        
        // === ЦЕНА: перебираем все возможные названия ===
        var priceNames = ["LAST", "LCURRENTPRICE", "MARKETPRICE", "PREVPRICE", "CLOSE", "CURRENTPRICE"];
        var priceFound = false;
        
        for (var p = 0; p < priceNames.length; p++) {
          var idx = mCols.indexOf(priceNames[p]);
          if (idx !== -1 && mRow[idx] !== undefined && mRow[idx] !== null && mRow[idx] !== "") {
            var val = parseFloat(mRow[idx]);
            if (!isNaN(val) && val > 0) {
              moexCache[actualIsin].price = val;
              priceFound = true;
              break;
            }
          }
        }
        
        // Если цена не найдена, пробуем через BID/OFFER
        if (!priceFound) {
          var bidIdx = mCols.indexOf("BID");
          var offerIdx = mCols.indexOf("OFFER");
          
          if (bidIdx !== -1 && offerIdx !== -1) {
            var bid = parseFloat(mRow[bidIdx]) || 0;
            var offer = parseFloat(mRow[offerIdx]) || 0;
            if (bid > 0 && offer > 0) {
              moexCache[actualIsin].price = (bid + offer) / 2;
              priceFound = true;
            }
          }
        }
        
        // === НКД: перебираем все возможные названия ===
        var nkdNames = ["ACCRUEDINT", "ACCRUEDINT_VALUE", "NKD", "ACCRUEDINTEREST"];
        
        for (var n = 0; n < nkdNames.length; n++) {
          var idx = mCols.indexOf(nkdNames[n]);
          if (idx !== -1 && mRow[idx] !== undefined && mRow[idx] !== null && mRow[idx] !== "") {
            var val = parseFloat(mRow[idx]);
            if (!isNaN(val) && val >= 0) {
              moexCache[actualIsin].nkd = val;
              break;
            }
          }
        }
      }
      
      successCount++;
      writeToLogSheet(
        "ИНФО", 
        "✓ " + actualIsin + " → цена: " + moexCache[actualIsin].price + 
        ", НКД: " + moexCache[actualIsin].nkd, 
        0
      );
      
    } catch(e) {
      writeToLogSheet("ОШИБКА", isin + " → " + e.message, 0);
      errorCount++;
    }
  }
  
  // ============================================================
  // ФИНАЛЬНЫЙ ОТЧЕТ
  // ============================================================
  
  var totalFound = Object.keys(moexCache).length;
  
  writeToLogSheet(
    "ИНФО", 
    "Загрузка завершена: найдено " + totalFound + " из " + allIsins.length + 
    " (ошибок: " + errorCount + ", не найдено: " + notFoundCount + ")", 
    totalFound
  );
  
  if (totalFound > 0) {
    writeToLogSheet("УСПЕХ", "Данные загружены для " + totalFound + " биржевых бумаг", totalFound);
  } else {
    writeToLogSheet("ОШИБКА", "Не удалось загрузить данные ни по одной бумаге!", 0);
  }
  
  // Информируем о внебиржевых бумагах
  if (notFoundCount > 0) {
    writeToLogSheet(
      "ИНФО", 
      "Внебиржевые бумаги пропущены — данные вносятся вручную", 
      0
    );
  }
  
  return moexCache;
}

// ============================================================
// БЛОК 3. МАТЕМАТИЧЕСКИЙ ДВИЖОК: ДИНАМИЧЕСКИЙ РАСЧЕТ ЧИСТОЙ YTM И СИГНАЛОВ
// ============================================================

/**
 * Рассчитывает внутреннюю норму доходности (YTM/XIRR) для облигации на основе денежных потоков
 * @param {number} currentPricePct Текущая чистая цена в % от номинала (например, 98.5)
 * @param {number} faceValue Номинал облигации (например, 1000)
 * @param {number} nkd Накопленный купонный доход (₽)
 * @param {number} couponValue Размер купона (₽)
 * @param {number} frequency Количество выплат в год
 * @param {string} maturityStr Дата погашения в формате YYYY-MM-DD
 * @return {number} Годовая доходность к погашению (в долях, например 0.215 для 21.5%)
 */
function calculateExactYTM(currentPricePct, faceValue, nkd, couponValue, frequency, maturityStr) {
  if (!currentPricePct || currentPricePct <= 0 || !maturityStr) return 0;
  
  var today = new Date();
  today.setHours(0, 0, 0, 0);
  
  var maturityDate = parseDateLocal(maturityStr);
  if (!maturityDate || maturityDate <= today) return 0;
  
  // Полная (грязная) цена покупки одной облигации
  var dirtyPrice = (currentPricePct / 100) * faceValue + nkd;
  
  // Расчет оставшихся дней до погашения
  var daysToMaturity = Math.ceil((maturityDate.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));
  if (daysToMaturity <= 0) return 0;
  
  // Строим приближенный календарь будущих выплат купонов
  var monthsStep = 12 / (frequency || 2);
  var cashFlows = [];
  
  // Первый денежный поток — покупка облигации (отрицательное значение)
  cashFlows.push({ date: new Date(today.getTime()), amount: -dirtyPrice });
  
  var tempDate = new Date(maturityDate.getTime());
  
  // Идем назад от даты погашения, чтобы восстановить даты купонов
  while (tempDate > today) {
    cashFlows.push({ date: new Date(tempDate.getTime()), amount: couponValue });
    tempDate.setMonth(tempDate.getMonth() - monthsStep);
  }
  
  // В дату погашения также возвращается номинал
  if (cashFlows.length > 1) {
    cashFlows[1].amount += faceValue; 
  }
  
  // Сортируем денежные потоки по дате (от ранних к поздним)
  cashFlows.sort(function(a, b) { return a.date - b.date; });
  
  // Алгоритм Ньютона-Рафсона для нахождения внутренней ставки доходности (XIRR)
  var rate = 0.15; // Начальное приближение (15%)
  for (var iteration = 0; iteration < 50; iteration++) {
    var fValue = 0;
    var fDerivative = 0;
    
    for (var i = 0; i < cashFlows.length; i++) {
      var d = Math.ceil((cashFlows[i].date - cashFlows[0].date) / (1000 * 60 * 60 * 24)) / 365;
      var expTerm = Math.pow(1 + rate, d);
      
      fValue += cashFlows[i].amount / expTerm;
      fDerivative -= d * cashFlows[i].amount / (expTerm * (1 + rate));
    }
    
    if (Math.abs(fDerivative) < 1e-10) break;
    
    var newRate = rate - fValue / fDerivative;
    if (Math.abs(newRate - rate) < 1e-6) {
      rate = newRate;
      break;
    }
    rate = newRate;
  }
  
  return (rate > 0 && rate < 2) ? rate : 0;
}

/**
 * Генерирует текстовый индикатор и рекомендацию на основе значения доходности (YTM)
 */
function generateMarketSignal(ytmPercent, maturityStr) {
  var dateLabel = maturityStr ? " до " + maturityStr : "";
  if (!ytmPercent || ytmPercent <= 0) {
    return "⚪ Нет данных YTM";
  }
  
  // Текущие пороговые значения доходностей на 2026 год
  if (ytmPercent > 23.0) {
    return "🔥 КУПИТЬ ЕЩЕ (YTM " + ytmPercent.toFixed(2) + "%" + dateLabel + ")";
  } else if (ytmPercent >= 16.0) {
    return "🟢 Держать (YTM " + ytmPercent.toFixed(2) + "%" + dateLabel + ")";
  } else {
    return "🚨 ПРОДАТЬ/ПЕРЕЛОЖИТЬ (YTM " + ytmPercent.toFixed(2) + "%" + dateLabel + ")";
  }
}



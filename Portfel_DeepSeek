// БЛОК 9. ШЛЮЗ АВТОДОБАВЛЕНИЯ НОВЫХ БУМАГ С ПРОВЕРКОЙ ISIN
// ============================================================================

function autoAddNewBondsFromCalendar() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var bondSheet = ss.getSheetByName("Облигации");
  var calSheet = ss.getSheetByName("КалендарьИнвестора");
  
  if (!bondSheet || !calSheet || calSheet.getLastRow() < 2) {
    writeToLogSheet("ПРЕДУПРЕЖДЕНИЕ", "Лист 'Облигации' или 'КалендарьИнвестора' не найден или пуст", 0);
    return;
  }
  
  // 1. Собираем список уже существующих ISIN в базе облигаций
  var existingIsins = {};
  var bondLastRow = bondSheet.getLastRow();
  if (bondLastRow >= 2) {
    var bondIsins = bondSheet.getRange("A2:A" + bondLastRow).getValues();
    for (var i = 0; i < bondIsins.length; i++) {
      var bIsin = String(bondIsins[i][0]).trim().toUpperCase();
      if (bIsin) existingIsins[bIsin] = true;
    }
  }
  
  // 2. Читаем ISIN из календаря выплат
  var calLastRow = calSheet.getLastRow();
  var calIsins = calSheet.getRange("B2:B" + calLastRow).getValues();
  var calNames = calSheet.getRange("A2:A" + calLastRow).getValues();
  
  // 3. Получаем быстрый пакетный кэш со всей биржи MOEX
  var moexCache = fetchAllMoexDataBatch();
  var newBondsData = [];
  var invalidIsins = [];
  var notFoundIsins = [];
  var alreadyExistIsins = [];
  
  writeToLogSheet("ИНФО", "Проверка " + calIsins.length + " ISIN из календаря...", 0);
  
  for (var j = 0; j < calIsins.length; j++) {
    var targetIsin = String(calIsins[j][0]).trim().toUpperCase();
    var emitterName = String(calNames[j][0]).trim();
    
    // Пропускаем технические строки
    if (!targetIsin || targetIsin === "" || targetIsin === "ИТОГ_МЕСЯЦ" || targetIsin.indexOf("ИТОГ") !== -1) {
      continue;
    }
    
    // ============================================================
    // ПРОВЕРКА 1: Валидность формата ISIN
    // ============================================================
    if (!isValidIsinFormat(targetIsin)) {
      if (invalidIsins.indexOf(targetIsin) === -1) {
        invalidIsins.push(targetIsin);
      }
      continue;
    }
    
    // ============================================================
    // ПРОВЕРКА 2: Уже существует в базе
    // ============================================================
    if (existingIsins[targetIsin]) {
      if (alreadyExistIsins.indexOf(targetIsin) === -1) {
        alreadyExistIsins.push(targetIsin);
      }
      continue;
    }
    
    // ============================================================
    // ПРОВЕРКА 3: Существует на MOEX
    // ============================================================
    if (!moexCache[targetIsin]) {
      if (notFoundIsins.indexOf(targetIsin) === -1) {
        notFoundIsins.push(targetIsin);
      }
      continue;
    }
    
    // ============================================================
    // ВСЕ ПРОВЕРКИ ПРОЙДЕНЫ - ДОБАВЛЯЕМ БУМАГУ
    // ============================================================
    var moexInfo = moexCache[targetIsin];
    
    // Формируем новую строку (20 колонок)
    var newRow = new Array(20).fill("");
    
    newRow[0] = targetIsin;                               // Столбец A: ISIN
    newRow[1] = emitterName || "Новый выпуск";            // Столбец B: Название
    newRow[6] = moexInfo.maturity || "";                  // Столбец G: Дата погашения
    newRow[9] = moexInfo.period || 2;                     // Столбец J: Купонов в год
    newRow[10] = moexInfo.price || 100;                   // Столбец K: Цена (%)
    newRow[11] = moexInfo.nkd || 0;                       // Столбец L: НКД
    newRow[13] = moexInfo.faceValue || 1000;              // Столбец N: Номинал
    newRow[15] = moexInfo.couponValue || 0;               // Столбец P: Купон (₽)
    
    newBondsData.push(newRow);
    existingIsins[targetIsin] = true; // Защита от дублирования
  }
  
  // ============================================================
  // ЛОГИРУЕМ РЕЗУЛЬТАТЫ ПРОВЕРКИ
  // ============================================================
  
  if (invalidIsins.length > 0) {
    writeToLogSheet(
      "ПРЕДУПРЕЖДЕНИЕ", 
      "Некорректный формат ISIN (" + invalidIsins.length + " шт.): " + invalidIsins.join(", "), 
      invalidIsins.length
    );
  }
  
  if (notFoundIsins.length > 0) {
    writeToLogSheet(
      "ПРЕДУПРЕЖДЕНИЕ", 
      "Не найдены на MOEX (" + notFoundIsins.length + " шт.): " + notFoundIsins.join(", "), 
      notFoundIsins.length
    );
  }
  
  if (alreadyExistIsins.length > 0) {
    writeToLogSheet(
      "ИНФО", 
      "Уже есть в базе (" + alreadyExistIsins.length + " шт.): " + alreadyExistIsins.join(", "), 
      alreadyExistIsins.length
    );
  }
  
  // ============================================================
  // 4. ПАКЕТНАЯ ДОЗАПИСЬ НОВЫХ БУМАГ
  // ============================================================
  
  if (newBondsData.length > 0) {
    var startRow = bondSheet.getLastRow() + 1;
    bondSheet.getRange(startRow, 1, newBondsData.length, 20).setValues(newBondsData);
    
    writeToLogSheet("УСПЕХ", "Добавлено новых бумаг в базу: " + newBondsData.length, newBondsData.length);
    
    // Принудительно запускаем перерасчет YTM для добавленных позиций
    updateAllBondValuesFromCache();
  } else {
    var totalChecked = calIsins.length;
    var skipped = invalidIsins.length + notFoundIsins.length + alreadyExistIsins.length;
    writeToLogSheet("ИНФО", "Новых бумаг не найдено. Проверено " + totalChecked + ", пропущено " + skipped, 0);
  }
}


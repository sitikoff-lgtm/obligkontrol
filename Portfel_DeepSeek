function updateAllBondValuesFromCache() {
  // Фиксируем запуск в системных логах
  writeToLogSheet("ИНФО", "Запуск пакетного обновления параметров облигаций...", 0);
  
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Облигации");
  if (!sheet) {
    writeToLogSheet("ОШИБКА", "Лист 'Облигации' не найден в книге!", 0);
    return;
  }
  
  var lastRow = sheet.getLastRow();
  if (lastRow < 2) {
    writeToLogSheet("ИНФО", "Таблица облигаций пустая (нет строк для обновления).", 0);
    return;
  }
  
  // 1. Запрашиваем кэш Мосбиржи через Блок 2
  var moexCache = {};
  try {
    moexCache = fetchAllMoexDataBatch();
    var cacheSize = Object.keys(moexCache).length;
    writeToLogSheet("ИНФО", "Сервер MOEX успешно ответил. В кэш загружено " + cacheSize + " инструментов.", 0);
  } catch(e) {
    writeToLogSheet("ОШИБКА", "Сбой при запросе к API Мосбиржи: " + e.message, 0);
    return;
  }
  
  // Считываем коды ISIN из столбца А
  var isins = sheet.getRange("A2:A" + lastRow).getValues();
  
  // Создаем изолированные вертикальные массивы для пакетного вывода
  var priceData = [];     // Столбец I (9)  - цены %
  var faceValueData = []; // Столбец J (10) - Новый вчерашний номинал
  var nkdData = [];       // Столбец L (12) - НКД ₽
  var oldFaceData = [];   // Столбец O (15) - Исторический номинал
  
  var updatedCount = 0;
  var notFoundBonds = [];
  
  // 2. Построчная обработка кодов ISIN вашего портфеля
  for (var i = 0; i < isins.length; i++) {
    var isin = String(isins[i]).replace(/[^A-Z0-9]/gi, '').trim().toUpperCase();
    
    // Бэкап текущих ячеек на случай пропусков данных в выходные дни
    var oldPrice = sheet.getRange(i + 2, 9).getValue();
    var oldFace = sheet.getRange(i + 2, 10).getValue();
    var oldNkd = sheet.getRange(i + 2, 12).getValue();
    var oldFaceO = sheet.getRange(i + 2, 15).getValue();
    
    // Переводим старую цену из формата "95,79%" в чистое число 95.79 для математики
    var cleanOldPrice = typeof oldPrice === "string" ? parseFloat(oldPrice.replace(/,/g, '.').replace(/%/g, '')) : parseFloat(oldPrice);
    if (isNaN(cleanOldPrice) || cleanOldPrice <= 0) cleanOldPrice = 100.0;
    
    if (isin && moexCache[isin]) {
      var bondInfo = moexCache[isin];
      
      // Если рыночная цена с биржи пустая или нулевая, защищаем ячейку старой ценой из таблицы
      var finalPrice = (bondInfo.price && bondInfo.price > 0) ? bondInfo.price : cleanOldPrice;
      
      priceData.push([finalPrice / 100]); // Переводим в доли для корректного отображения %
      faceValueData.push([bondInfo.faceValue || 1000]);
      nkdData.push([bondInfo.nkd || 0]);
      oldFaceData.push([bondInfo.faceValue || 1000]);
      updatedCount++;
    } else {
      // Если ISIN не найден на Мосбирже, жестко сохраняем все старые параметры строки портфеля
      if (isin) notFoundBonds.push(isin);
      priceData.push([typeof oldPrice === "number" ? oldPrice : cleanOldPrice / 100]);
      faceValueData.push([oldFace || 1000]);
      nkdData.push([oldNkd || 0]);
      oldFaceData.push([oldFaceO || 1000]);
    }
  }
  
  // 3. Безопасная пакетная выгрузка сформированных массивов в таблицу
  try {
    // Цены в % от номинала — Столбец I
    sheet.getRange("I2:I" + lastRow).setValues(priceData).setNumberFormat('0.00%');
    
    // Текущий вчерашний номинал — Столбец J (Ваша новая колонка)
    sheet.getRange("J2:J" + lastRow).setValues(faceValueData).setNumberFormat('#,##0.00" ₽"');
    
    // Накопленный купонный доход в рублях — Столбец L
    sheet.getRange("L2:L" + lastRow).setValues(nkdData).setNumberFormat('#,##0.00');
    
    // Текущий номинал (исторический) — Столбец O
    sheet.getRange("O2:O" + lastRow).setValues(oldFaceData).setNumberFormat('#,##0.00" ₽"');
    
    // Формируем итоговый отчет в ленту логов
    var successMsg = "Пакетная запись параметров завершена.";
    if (notFoundBonds.length > 0) {
      successMsg += " Внимание, " + notFoundBonds.length + " шт. ISIN не найдены на MOEX: " + notFoundBonds.join(", ");
    }
    writeToLogSheet("УСПЕХ", successMsg, updatedCount);
    
  } catch(err) {
    writeToLogSheet("ОШИБКА", "Критический сбой записи массивов на лист Облигации: " + err.message, 0);
  }
  
  SpreadsheetApp.flush();
}



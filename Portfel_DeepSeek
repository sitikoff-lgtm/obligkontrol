function checkPortfolioHealth() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var logSheet = ss.getSheetByName("Логи");
  
  if (!logSheet) {
    SpreadsheetApp.getUi().alert("❌ Лист 'Логи' отсутствует. Запусти обновление портфеля.");
    return;
  }
  
  var lastRow = logSheet.getLastRow();
  if (lastRow < 2) {
    SpreadsheetApp.getUi().alert("ℹ️ Логов пока нет. Запусти обновление портфеля.");
    return;
  }
  
  // Читаем последние 5 записей
  var startRow = Math.max(2, lastRow - 4);
  var logs = logSheet.getRange(startRow, 2, lastRow - startRow + 1, 3).getValues();
  
  var message = "📊 **Последние события портфеля:**\n\n";
  for (var i = 0; i < logs.length; i++) {
    var status = logs[i][0];
    var text = logs[i][1];
    var count = logs[i][2];
    
    var emoji = "●";
    if (status === "УСПЕХ") emoji = "✅";
    else if (status === "ОШИБКА") emoji = "❌";
    else if (status === "ПРЕДУПРЕЖДЕНИЕ") emoji = "⚠️";
    else if (status === "ИНФО") emoji = "ℹ️";
    
    message += emoji + " " + status + ": " + text + (count > 0 ? " (" + count + ")" : "") + "\n";
  }
  
  SpreadsheetApp.getUi().alert(message);
}

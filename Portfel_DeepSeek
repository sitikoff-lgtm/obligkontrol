/**
 * Показывает последние 10 записей из логов в диалоговом окне
 */
function showLastLogs() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var logSheet = ss.getSheetByName("Логи");
  
  if (!logSheet) {
    SpreadsheetApp.getUi().alert("❌ Лист 'Логи' не найден. Запусти обновление портфеля, чтобы создать его.");
    return;
  }
  
  var lastRow = logSheet.getLastRow();
  if (lastRow < 2) {
    SpreadsheetApp.getUi().alert("ℹ️ Логов пока нет. Запусти обновление портфеля.");
    return;
  }
  
  // Читаем последние 10 записей
  var startRow = Math.max(2, lastRow - 9);
  var logs = logSheet.getRange(startRow, 1, lastRow - startRow + 1, 4).getValues();
  
  // Формируем сообщение
  var message = "📋 **ПОСЛЕДНИЕ " + logs.length + " СОБЫТИЙ:**\n";
  message += "═══════════════════════════════════════\n\n";
  
  for (var i = 0; i < logs.length; i++) {
    var time = logs[i][0];
    var status = logs[i][1];
    var text = logs[i][2];
    var count = logs[i][3];
    
    var emoji = "●";
    if (status === "УСПЕХ") emoji = "✅";
    else if (status === "ОШИБКА") emoji = "❌";
    else if (status === "ПРЕДУПРЕЖДЕНИЕ") emoji = "⚠️";
    else if (status === "ИНФО") emoji = "ℹ️";
    
    message += emoji + " " + time + " | " + status;
    if (count > 0) message += " (" + count + " шт.)";
    message += "\n   " + text + "\n\n";
  }
  
  // Показываем в диалоге (ограничение по длине)
  if (message.length > 50000) {
    message = message.substring(0, 49000) + "\n... (логи слишком длинные, откройте лист 'Логи')";
  }
  
  SpreadsheetApp.getUi().alert(message);
}

/**
 * Проверяет статус портфеля и показывает сводку
 */
function checkPortfolioHealth() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var logSheet = ss.getSheetByName("Логи");
  
  if (!logSheet) {
    SpreadsheetApp.getUi().alert("❌ Лист 'Логи' отсутствует. Запусти обновление портфеля.");
    return;
  }
  
  var lastRow = logSheet.getLastRow();
  if (lastRow < 2) {
    SpreadsheetApp.getUi().alert("ℹ️ Логов пока нет. Запусти обновление портфеля.");
    return;
  }
  
  // Считаем статистику по статусам
  var allLogs = logSheet.getRange(2, 2, lastRow - 1, 2).getValues();
  var stats = {
    УСПЕХ: 0,
    ОШИБКА: 0,
    ПРЕДУПРЕЖДЕНИЕ: 0,
    ИНФО: 0
  };
  
  var lastErrors = [];
  
  for (var i = 0; i < allLogs.length; i++) {
    var status = allLogs[i][0];
    var message = allLogs[i][1];
    
    if (stats.hasOwnProperty(status)) {
      stats[status]++;
    }
    
    // Собираем последние 3 ошибки
    if (status === "ОШИБКА" && lastErrors.length < 3) {
      lastErrors.push(message);
    }
  }
  
  // Формируем отчет
  var total = allLogs.length;
  var message = "📊 **СТАТУС ПОРТФЕЛЯ**\n";
  message += "═══════════════════════════════\n\n";
  message += "📝 Всего записей: " + total + "\n\n";
  message += "✅ Успешно: " + stats.УСПЕХ + "\n";
  message += "⚠️ Предупреждений: " + stats.ПРЕДУПРЕЖДЕНИЕ + "\n";
  message += "❌ Ошибок: " + stats.ОШИБКА + "\n";
  message += "ℹ️ Информации: " + stats.ИНФО + "\n\n";
  
  // Показываем здоровье портфеля
  var health = "🟢 Отлично";
  if (stats.ОШИБКА > 0) {
    health = "🔴 Требуется внимание!";
    message += "⚠️ **Последние ошибки:**\n";
    for (var j = 0; j < lastErrors.length; j++) {
      message += "  • " + lastErrors[j] + "\n";
    }
    message += "\n";
  }
  message += "💚 Состояние: " + health;
  
  SpreadsheetApp.getUi().alert(message);
}

/**
 * Очищает все логи (оставляет только шапку)
 */
function clearLogs() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var logSheet = ss.getSheetByName("Логи");
  
  if (!logSheet) {
    SpreadsheetApp.getUi().alert("❌ Лист 'Логи' не найден.");
    return;
  }
  
  var lastRow = logSheet.getLastRow();
  if (lastRow <= 1) {
    SpreadsheetApp.getUi().alert("ℹ️ Логи уже пусты.");
    return;
  }
  
  // Запрашиваем подтверждение
  var response = SpreadsheetApp.getUi().alert(
    "⚠️ Подтверждение очистки",
    "Вы уверены, что хотите удалить все логи? (Будет оставлена только шапка таблицы)",
    SpreadsheetApp.getUi().ButtonSet.YES_NO
  );
  
  if (response === SpreadsheetApp.getUi().Button.YES) {
    logSheet.deleteRows(2, lastRow - 1);
    writeToLogSheet("ИНФО", "Логи очищены пользователем вручную", 0);
    SpreadsheetApp.getUi().alert("✅ Логи успешно очищены.");
  }
}



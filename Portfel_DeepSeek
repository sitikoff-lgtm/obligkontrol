// БЛОК 7. ЧАСТЬ 1: ПОДКЛЮЧЕНИЕ К КАЛЕНДАРЮ И ОЧИСТКА
// ============================================================================

function syncPaymentsWithGoogleCalendar() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Свод_Календарь");
  if (!sheet || sheet.getLastRow() < 2) return;
  
  var data = sheet.getRange(2, 1, sheet.getLastRow() - 1, 10).getDisplayValues();
  var calName = "💼 Инвестиции БКС (Купоны)";
  var calendars = CalendarApp.getCalendarsByName(calName);
  var cal = (calendars.length > 0) ? calendars[0] : CalendarApp.createCalendar(calName);
  
  // Очистка старых событий, чтобы избежать дубликатов
  var oldEvents = cal.getEvents(new Date(2020, 0, 1), new Date(3000, 0, 1));
  for (var i = 0; i < oldEvents.length; i++) { oldEvents[i].deleteEvent(); }
  
  // Переход к следующей части
  processCalendarEventsLoop(cal, data, 0);
}
// ============================================================================
// БЛОК 7. ЧАСТЬ 2: АНАЛИЗ СТРОК И ФОРМИРОВАНИЕ УМНЫХ ЗАГОЛОВКОВ
// ============================================================================

function processCalendarEventsLoop(cal, data, count) {
  for (var j = 0; j < data.length; j++) {
    var name = String(data[j][1]).trim();
    var isin = String(data[j][2]).trim();
    var rawDateStr = String(data[j][3]).trim();
    var cleanSum = data[j][8];
    var signal = String(data[j][9]).trim();
    
    // Пропускаем технические строки итогов
    if (name === "ИТОГ_МЕСЯЦ" || name === "" || name.indexOf("ИТОГ") !== -1) continue;
    
    var parts = rawDateStr.split('.');
    if (parts.length !== 3) continue;
    
    var day = parseInt(parts[0], 10);
    var month = parseInt(parts[1], 10) - 1;
    var year = parseInt(parts[2], 10);
    
    var eventDate = new Date(year, month, day, 10, 0, 0);
    if (isNaN(eventDate.getTime())) continue;
    
    // Выстраиваем заголовок на основе рыночных сигналов
    var title = "💰 Купон: " + name + " (+" + cleanSum + " ₽)";
    if (signal.indexOf("🚨") !== -1) title = "🚨 ПРОДАТЬ " + name + "!";
    if (signal.indexOf("🔥") !== -1) title = "🔥 КУПИТЬ " + name + "!";
    
    // Передаем сформированные данные в финальный блок для создания события
    count = writeSingleEventToCalendar(cal, title, eventDate, name, isin, cleanSum, signal, count);
  }
  
  // Сообщаем пользователю об успешном завершении всей синхронизации
  SpreadsheetApp.getUi().alert("🚀 Синхронизация завершена! Успешно добавлено " + count + " инвест-событий.");
}

// ============================================================================
// ОБНОВЛЕННЫЙ БЛОК 7. ЧАСТЬ 3. ПЕЧАТЬ КОЛИЧЕСТВА И СТОИМОСТИ КУПОНА В КАЛЕНДАРЬ
// ============================================================================

function writeSingleEventToCalendar(cal, title, eventDate, name, isin, cleanSum, signal, count) {
  var actionPlan = "";
  
  if (signal.indexOf("🚨") !== -1) {
    actionPlan = "💡 АНАЛИТИКА БКС:\n⚠ Бумага перегрета, доходность упала. Рекомендуется ПРОДАТЬ выпуск в приложении БКС.";
  } else if (signal.indexOf("🔥") !== -1) {
    actionPlan = "💡 АНАЛИТИКА БКС:\n📈 Высокая доходность! Цена занижена. Рекомендуется ИСПОЛЬЗОВАТЬ купоны для ДОКУПКИ.";
  } else {
    actionPlan = "💡 АНАЛИТИКА БКС:\n🟢 Стабильный плановый доход. Купоны отправляем на плановое реинвестирование.";
  }
  
  // Разбиваем переданную строку, чтобы вытащить инфо о штуках
  var detailsText = "Пакет выплат";
  if (signal.indexOf("|") !== -1) {
    detailsText = "• " + signal.split("|")[1].trim();
  }
  
  // Формируем красивую карточку описания
  var description = "📋 СВОДКА ПО ВЫПЛАТЕ:\n" +
                    "• Облигация: " + name + "\n" +
                    "• Код ISIN: " + isin + "\n" +
                    detailsText + "\n" + // Сюда встанет: "• Итого: X шт. (по ~Y ₽ чистыми)"
                    "• Общая сумма чистыми: " + cleanSum + " ₽\n" +
                    "• Статус YTM: " + signal.split("|")[0].trim() + "\n\n" +
                    "----------------------------------------\n" +
                    actionPlan;
                    
  try {
    cal.createEvent(title, eventDate, eventDate, {description: description});
    count++;
  } catch(e) {
    Logger.log("Ошибка записи события: " + e.toString());
  }
  
  return count;
}


// ============================================================================
// БЛОК 8. ЧАСТЬ 1: ПОТОКОВЫЙ ПАРСЕР ЛЕНТЫ БКС — СБОР СТРОК И ИДЕНТИФИКАЦИЯ ISIN
// ============================================================================

function cleanBksVerticalText() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("КалендарьИнвестора");
  if (!sheet) return;
  
  var lastRow = sheet.getLastRow();
  if (lastRow < 1) return;
  
  var rawValues = sheet.getRange(1, 1, lastRow, 1).getDisplayValues();
  var lines = [];
  
  // Отсекаем пустые строки и убираем лишние пробелы
  for (var k = 0; k < rawValues.length; k++) {
    var lineText = String(rawValues[k]).trim();
    if (lineText !== "") lines.push(lineText);
  }
  
  var cleanRows = [];
  var currentObj = null;
  
  // Построчный разбор текста ленты выплат
  for (var p = 0; p < lines.length; p++) {
    var line = lines[p];
    
    // Пропускаем мусорные заголовки БКС ленты
    if (line === "Дата отсечки" || line === "Сумма" || line === "Купон" || line === "₽" || line === "%") {
      continue;
    }
    
    // Регулярное выражение для поиска стандартного кода ISIN
    var isinMatch = line.match(/^(RU|SU)[A-Z0-9]{10}$/i) || (line === "MGKL1P3");
    
    if (isinMatch) {
      // Сохраняем предыдущий объект, если он был полностью собран
      if (currentObj && currentObj.isin && currentObj.dirty > 0) {
        cleanRows.push(buildFinalBksArray(currentObj));
      }
      
      var finalIsin = line.toUpperCase().trim();
      if (finalIsin === "MGKL1P3") finalIsin = "RU000A10FDE3"; // Маппинг частного случая
      
      currentObj = {
        name: (p >= 1) ? lines[p-1] : "Облигация",
        isin: finalIsin,
        date: "",
        qty: 0,
        rate: "0,00%",
        dirty: 0
      };
      
      // Защита: если имя совпало с кодом, берем строку еще выше
      if (currentObj.name === currentObj.isin && p >= 2) currentObj.name = lines[p-2];
      continue;
    }
    
    // Передаем наполнение параметров (даты, количества, суммы) во вторую часть
    parseBksDetailsLine(line, currentObj);
  }
  
  // Передаем собранные чистые строки в функцию финализации
  flushBksCleanRowsToSheet(sheet, cleanRows, currentObj);
}
// ============================================================================
// БЛОК 8. ЧАСТЬ 2: РАСПОЗНАВАНИЕ ФИНАНСОВЫХ СУММ И ПЕРЕЗАПИСЬ ТАБЛИЦЫ
// ============================================================================

/**
 * Разбирает значения внутренних параметров (даты, количества, суммы) из текущей строки
 */
function parseBksDetailsLine(line, currentObj) {
  if (!currentObj) return;
  
  // Регулярное выражение для поиска дат формата ДД.ММ.ГГГГ
  var dateMatch = line.match(/^\d{2}\.\d{2}\.\d{4}$/);
  if (dateMatch) {
    currentObj.date = line;
    return;
  }
  
  // Находим процентные ставки купона
  if (line.indexOf('%') !== -1) {
    currentObj.rate = line;
    return;
  }
  
  // Находим количество штук (если строка заканчивается на шт.)
  if (line.toLowerCase().indexOf('шт') !== -1 || line.toLowerCase().indexOf('pcs') !== -1) {
    currentObj.qty = parseFloat(line.replace(/[^0-9]/g, '')) || 0;
    return;
  }
  
  // Если строка содержит валюту или является просто числом с запятой — это сумма выплаты
  if (line.indexOf('₽') !== -1 || line.indexOf(',') !== -1 || !isNaN(parseFloat(line.replace(/\s/g, '').replace(',', '.')))) {
    var val = parseFloat(line.replace(/[^\d.,-]/g, '').replace(/\s/g, '').replace(',', '.')) || 0;
    if (val > 0 && currentObj.dirty === 0) {
      currentObj.dirty = val;
    }
  }
}

/**
 * Формирует одномерный упорядоченный массив для выгрузки в строки таблицы
 */
function buildFinalBksArray(obj) {
  var ndfl = Math.round((obj.dirty * 0.13) * 100) / 100;
  var clean = Math.round((obj.dirty - ndfl) * 100) / 100;
  
  return [
    obj.name,     // А: Эмитент
    obj.isin,     // B: ISIN
    obj.date,     // C: Дата отсечки
    obj.qty,      // D: Кол-во шт
    obj.rate,     // E: Ставка купона
    obj.dirty,    // F: Сумма грязными
    ndfl,         // G: НДФЛ
    clean         // H: Сумма чистыми
  ];
}

/**
 * Очищает лист и выполняет пакетную запись структурированных данных БКС
 */
function flushBksCleanRowsToSheet(sheet, cleanRows, currentObj) {
  // Добавляем самый последний объект, если он не был добавлен в цикле
  if (currentObj && currentObj.isin && currentObj.dirty > 0) {
    cleanRows.push(buildFinalBksArray(currentObj));
  }
  
  if (cleanRows.length === 0) return;
  
  sheet.clear();
  
  // Создаем стандартные заголовки для листа КалендарьИнвестора
  var headers = [["Эмитент / Выпуск", "ISIN", "Дата отсечки", "Кол-во (шт)", "Ставка (%)", "Сумма грязными (₽)", "НДФЛ 13% (₽)", "Сумма чистыми (₽)"]];
  sheet.getRange(1, 1, 1, 8).setValues(headers).setFontWeight("bold").setBackground("#e6effa");
  
  // Пакетная запись чистых строк
  sheet.getRange(2, 1, cleanRows.length, 8).setValues(cleanRows);
  
  // Наводим косметический порядок: форматы чисел и авто-ширина столбцов
  sheet.getRange("D2:D" + (cleanRows.length + 1)).setNumberFormat('#,##0');
  sheet.getRange("F2:H" + (cleanRows.length + 1)).setNumberFormat('#,##0.00');
  sheet.autoResizeColumns(1, 8);
  
  SpreadsheetApp.flush();
}

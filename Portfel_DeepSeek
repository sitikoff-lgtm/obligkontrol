        message += "\nНоминал: " + face;
        message += "\nДата погашения: " + maturity;
        message += "\nКупон: " + coupon;
        message += "\nЦена (последняя): " + price;
        
        writeToLogSheet("ИНФО", "Тест MOEX: " + testIsin + " найден, цена " + price, 0);

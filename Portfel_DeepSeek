// ============================================================================
// ТЕСТ 2: Проверка списка ISIN на MOEX (С УЛУЧШЕННЫМ ПАРСИНГОМ)
// ============================================================================

function testAllIsinsOnMoex() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var calSheet = ss.getSheetByName("КалендарьИнвестора");
    
    if (!calSheet || calSheet.getLastRow() < 2) {
      writeToLogSheet("ОШИБКА", "Лист 'КалендарьИнвестора' пуст или не найден", 0);
      return;
    }
    
    var calLastRow = calSheet.getLastRow();
    var calIsins = calSheet.getRange("B2:B" + calLastRow).getValues();
    var calNames = calSheet.getRange("A2:A" + calLastRow).getValues();
    
    var results = [];
    var totalChecked = 0;
    var found = 0;
    var notFound = 0;
    var invalidIsins = [];
    var foundDetails = [];
    
    for (var i = 0; i < calIsins.length; i++) {
      var isin = String(calIsins[i][0]).trim().toUpperCase();
      var name = String(calNames[i][0]).trim();
      
      if (!isin || isin === "" || isin === "ИТОГ_МЕСЯЦ" || isin.indexOf("ИТОГ") !== -1) {
        continue;
      }
      
      totalChecked++;
      
      if (!isValidIsinFormat(isin)) {
        invalidIsins.push(isin + " (" + name + ")");
        results.push("⚠️ " + isin + " (" + name + ") - НЕВАЛИДНЫЙ ФОРМАТ");
        notFound++;
        continue;
      }
      
      var url = "https://moex.com/iss/securities.json?q=" + isin + "&iss.meta=off&iss.only=securities,marketdata";
      
      try {
        Utilities.sleep(200);
        
        var response = UrlFetchApp.fetch(url, {
          muteHttpExceptions: true,
          headers: {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
            'Accept': 'application/json'
          }
        });
        
        if (response.getResponseCode() === 200) {
          var json = JSON.parse(response.getContentText());
          
          var hasData = false;
          var price = "не найдена";
          var nkd = "не найден";
          var maturity = "не найдена";
          var coupon = "не найден";
          var faceValue = "не найден";
          
          // ============================================================
          // ПАРСИМ securities
          // ============================================================
          if (json && json.securities && json.securities.data && json.securities.data.length > 0) {
            hasData = true;
            
            var sCols = json.securities.columns;
            var sRow = json.securities.data[0];
            
            // Ищем индексы с запасными вариантами
            var nkdIdx = sCols.indexOf("ACCRUEDINT");
            if (nkdIdx === -1) nkdIdx = sCols.indexOf("ACCRUEDINT_VALUE");
            
            var matIdx = sCols.indexOf("MATDATE");
            if (matIdx === -1) matIdx = sCols.indexOf("MATURITYDATE");
            
            var faceIdx = sCols.indexOf("FACEVALUE");
            if (faceIdx === -1) faceIdx = sCols.indexOf("FACEVALUE_START");
            
            var cpnIdx = sCols.indexOf("COUPONVALUE");
            if (cpnIdx === -1) cpnIdx = sCols.indexOf("COUPONPERCENT");
            
            // Извлекаем значения
            nkd = nkdIdx !== -1 ? sRow[nkdIdx] : "не найден";
            maturity = matIdx !== -1 ? sRow[matIdx] : "не найдена";
            faceValue = faceIdx !== -1 ? sRow[faceIdx] : "не найден";
            coupon = cpnIdx !== -1 ? sRow[cpnIdx] : "не найден";
          }
          
          // ============================================================
          // ПАРСИМ marketdata (цены)
          // ============================================================
          if (json && json.marketdata && json.marketdata.data && json.marketdata.data.length > 0) {
            var mCols = json.marketdata.columns;
            var mRow = json.marketdata.data[0];
            
            // Ищем цену с запасными вариантами
            var priceIdx = mCols.indexOf("LAST");
            if (priceIdx === -1) priceIdx = mCols.indexOf("LCURRENTPRICE");
            if (priceIdx === -1) priceIdx = mCols.indexOf("MARKETPRICE");
            if (priceIdx === -1) priceIdx = mCols.indexOf("PREVPRICE");
            
            if (priceIdx !== -1 && mRow[priceIdx]) {
              price = mRow[priceIdx];
            }
            
            // Если цена не найдена, пробуем найти через BID/OFFER
            if (price === "не найдена" || price === "0") {
              var bidIdx = mCols.indexOf("BID");
              var offerIdx = mCols.indexOf("OFFER");
              var avgPrice = 0;
              
              if (bidIdx !== -1 && offerIdx !== -1) {
                var bid = parseFloat(mRow[bidIdx]) || 0;
                var offer = parseFloat(mRow[offerIdx]) || 0;
                if (bid > 0 && offer > 0) {
                  avgPrice = (bid + offer) / 2;
                  price = avgPrice.toString();
                }
              }
            }
          }
          
          // Если данные есть, добавляем в результат
          if (hasData) {
            var detail = isin + " → цена: " + price + ", НКД: " + nkd + ", купон: " + coupon;
            foundDetails.push(detail);
            results.push("✅ " + isin + " (" + name + ") - НАЙДЕН (цена: " + price + ")");
            found++;
          } else {
            results.push("❌ " + isin + " (" + name + ") - НЕТ ДАННЫХ");
            notFound++;
          }
        } else {
          results.push("❌ " + isin + " (" + name + ") - КОД " + response.getResponseCode());
          notFound++;
        }
      } catch(e) {
        results.push("❌ " + isin + " (" + name + ") - ОШИБКА: " + e.message);
        notFound++;
        writeToLogSheet("ОШИБКА", isin + ": " + e.message, 0);
      }
    }
    
    // ============================================================
    // ФОРМИРУЕМ ОТЧЕТ
    // ============================================================
    
    var report = "📊 **РЕЗУЛЬТАТ ПРОВЕРКИ ISIN НА MOEX**\n\n";
    report += "📝 Проверено: " + totalChecked + "\n";
    report += "✅ Найдено: " + found + "\n";
    report += "❌ Не найдено: " + notFound + "\n";
    
    if (invalidIsins.length > 0) {
      report += "⚠️ Невалидный формат: " + invalidIsins.length + "\n";
    }
    
    if (foundDetails.length > 0) {
      report += "\n📋 **Найденные бумаги (с данными):**\n";
      // Показываем только уникальные записи
      var uniqueDetails = foundDetails.filter(function(item, index) {
        return foundDetails.indexOf(item) === index;
      });
      report += uniqueDetails.slice(0, 10).join("\n");
      if (uniqueDetails.length > 10) {
        report += "\n... и еще " + (uniqueDetails.length - 10) + " записей";
      }
    }
    
    report += "\n\n═══════════════════════════════\n";
    var displayResults = results.slice(0, 30);
    if (results.length > 30) {
      displayResults.push("... и еще " + (results.length - 30) + " записей");
    }
    report += displayResults.join("\n");
    
    writeToLogSheet("ИНФО", "Тест всех ISIN: найдено " + found + " из " + totalChecked, found);
    
    try {
      var ui = SpreadsheetApp.getUi();
      if (report.length > 50000) {
        report = report.substring(0, 49000) + "\n\n... (обрезано)";
      }
      ui.alert(report);
    } catch(e) {
      writeToLogSheet("ИНФО", "Отчет сгенерирован (UI недоступен)", 0);
      Logger.log(report);
    }
    
  } catch(e) {
    writeToLogSheet("ОШИБКА", "testAllIsinsOnMoex: " + e.message, 0);
    Logger.log("Ошибка: " + e.message);
  }
}


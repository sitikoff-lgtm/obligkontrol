// БЛОК 6. ЧАСТЬ 4 ИЗ 5. ВЫГРУЗКА И СТИЛИЗАЦИЯ КАЛЕНДАРЯ
// ============================================================================

function flushCalendarToSheet(destSheet, finalData, totalRowsIndices, chartValues) {
  if (!finalData || finalData.length === 0) return;
  
  // 1. Пакетная выгрузка всей матрицы данных на лист
  var outputRange = destSheet.getRange(2, 1, finalData.length, 10);
  outputRange.setValues(finalData);
  
  // 2. Настройка числовых форматов: количество (целые), деньги (с копейками)
  destSheet.getRange("E2:E" + (finalData.length + 1)).setNumberFormat('#,##0');
  destSheet.getRange("G2:I" + (finalData.length + 1)).setNumberFormat('#,##0.00');
  
  // 3. Выравнивание текста, автоперенос строк и установка сетки границ
  var range = destSheet.getRange(1, 1, finalData.length + 1, 10);
  range.setBorder(true, true, true, true, true, true, "#d9d9d9", SpreadsheetApp.BorderStyle.SOLID)
       .setVerticalAlignment("middle")
       .setWrap(true);
       
  // Выравниваем названия эмитентов по левому краю для удобства чтения
  destSheet.getRange(2, 2, finalData.length, 1).setHorizontalAlignment("left");
  
  // 4. Визуальное выделение итоговых строк месяцев (делаем их жирными и серыми)
  for (var m = 0; m < totalRowsIndices.length; m++) {
    destSheet.getRange(totalRowsIndices[m], 1, 1, 10)
             .setFontWeight("bold")
             .setBackground("#eaedf1");
  }
  
  // 5. Передаем накопленные чистые доходы в финальный Блок 6.5 для построения графика
  renderAnalyticsChart2026(chartValues);
}


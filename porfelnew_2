function generateCalendarDataRows(destSheet) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sourceSheet = ss.getSheetByName("КалендарьИнвестора");
  if (!sourceSheet) return;
  
  var sourceLastRow = sourceSheet.getLastRow();
  if (sourceLastRow < 2) return;
  
  // Строго читаем все данные как ТЕКСТ во избежание сбоев дат
  var calData = sourceSheet.getRange(2, 1, sourceLastRow - 1, 8).getDisplayValues();
  var amortizationMap = getAmortizationData();
  
  var finalData = [];
  var chartValues = [];
  var totalRowsIndices = [];
  var monthsNames = ["ЯНВАРЬ", "ФЕВРАЛЬ", "МАРТ", "АПРЕЛЬ", "МАЙ", "ИЮНЬ", "ИЮЛЬ", "АВГУСТ", "СЕНТЯБРЬ", "ОКТЯБРЬ", "НОЯБРЬ", "ДЕКАБРЬ"];
  
  // Передаем управление в подфункцию обработки месяцев (Часть 3.2)
  processMonthsLoop(destSheet, calData, amortizationMap, finalData, chartValues, totalRowsIndices, monthsNames);
}
// ============================================================
// БЛОК 6. ЧАСТЬ 3.2.1. ФИЛЬТРАЦИЯ СТРОК ПО МЕСЯЦАМ
// ============================================================

function processMonthsLoop(destSheet, calData, amortizationMap, finalData, chartValues, totalRowsIndices, monthsNames) {
  // Проходим по каждому из 12 месяцев года
  for (var m = 0; m < monthsNames.length; m++) {
    var targetMonthName = monthsNames[m];
    var runningDirty = 0, runningNdfl = 0, runningClean = 0;
    var hasBondsInMonth = false;
    
    // Сканируем все строки из Календаря Инвестора
    for (var i = 0; i < calData.length; i++) {
      var dateStr = calData[i][2]; // Дата отсечки в текстовом виде
      if (!dateStr) continue;
      
      // Бьем дату через точку "ДД.ММ.ГГГГ"
      var parts = dateStr.split('.');
      if (parts.length !== 3) continue;
      
      // Проверяем, совпадает ли месяц (индекс с нуля, поэтому вычитаем 1)
      var bondMonthIdx = parseInt(parts[1], 10) - 1;
      if (bondMonthIdx === m) {
        hasBondsInMonth = true;
        
        // Передаем строку для расчета денег и YTM-сигнала в следующую микро-часть
        processSingleBondRow(calData[i], amortizationMap, finalData, targetMonthName, hasBondsInMonth);
        
        // Аккумулируем суммы
        runningDirty += parseFloat(calData[i][5].replace(/\s/g, '').replace(',', '.')) || 0;
        runningNdfl += parseFloat(calData[i][6].replace(/\s/g, '').replace(',', '.')) || 0;
        runningClean += parseFloat(calData[i][7].replace(/\s/g, '').replace(',', '.')) || 0;
      }
    }
    
    // Если в месяце были выплаты, добавляем строку "ИТОГ МЕСЯЦА"
    if (hasBondsInMonth) {
      var totalRowNum = finalData.length + 2; // +2 с учетом шапки таблицы
      finalData.push([
        "ИТОГ " + targetMonthName, "ИТОГ_МЕСЯЦ", "", "-", "-", "-",
        Math.round(runningDirty * 100) / 100, Math.round(runningNdfl * 100) / 100, Math.round(runningClean * 100) / 100, "-"
      ]);
      totalRowsIndices.push(totalRowNum);
      chartValues.push([targetMonthName, Math.round(runningClean * 100) / 100]);
    }
  }
  
  // Передаем накопленные массивы в Часть 4 для выгрузки на лист
  flushCalendarToSheet(destSheet, finalData, totalRowsIndices, chartValues);
}
// ============================================================
// БЛОК 6. ЧАСТЬ 3.2.2. РАСЧЕТ ОДНОЙ СТРОКИ ОБЛИГАЦИИ И СИГНАЛА YTM
// ============================================================

function processSingleBondRow(row, amortizationMap, finalData, targetMonthName, hasBondsInMonth) {
  var name = row[0];
  var isin = row[1];
  var dateStr = row[2];
  var qty = parseFloat(row[3]) || 0;
  var rateStr = row[4];
  
  // Извлекаем чистые финансовые значения
  var dirtyValue = parseFloat(row[5].replace(/\s/g, '').replace(',', '.')) || 0;
  var ndfl = parseFloat(row[6].replace(/\s/g, '').replace(',', '.')) || 0;
  var clean = parseFloat(row[7].replace(/\s/g, '').replace(',', '.')) || 0;
  
  // Метка месяца пишется только один раз на первую строчку группы
  var monthLabelToPrint = (finalData.length === 0 || finalData[finalData.length - 1][1] === "ИТОГ_МЕСЯЦ") ? targetMonthName : "";
  
  // По умолчанию — сигнала нет
  var signalText = "⚪ Нет данных YTM на листе Облигации";
  
  // Если бумага есть в нашей базе — генерируем умный рыночный сигнал
  if (isin && amortizationMap[isin]) {
    var currentYTM = amortizationMap[isin].ytm;
    var maturityStr = amortizationMap[isin].maturity || "";
    
    // Вызываем генератор сигналов из Блока 3
    signalText = generateMarketSignal(currentYTM, maturityStr);
  }
  
  // Добавляем готовую строчку в общую матрицу
  finalData.push([monthLabelToPrint, name, isin, dateStr, qty, rateStr, dirtyValue, ndfl, clean, signalText]);
}

/**
 * Сканирует лист "Облигации", подтягивает данные из кэша MOEX и обновляет рыночные параметры
 */
function updateAllBondValuesFromCache() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Облигации");
  if (!sheet) return;
  
  var lastRow = sheet.getLastRow();
  if (lastRow < 2) return;
  
  // Получаем кэш со всей биржи за 2 запроса
  var moexCache = fetchAllMoexDataBatch();
  
  // Читаем ключевые диапазоны для расчетов
  var isinRange = sheet.getRange("A2:A" + lastRow);
  var isins = isinRange.getValues();
  
  // Массивы для пакетной записи обратно в таблицу
  var priceData = [];    // Сюда пойдут рыночные цены (%)
  var nkdData = [];      // Накопленный купонный доход (₽)
  var ytmData = [];      // Рассчитанная чистая доходность YTM (%)
  
  for (var i = 0; i < isins.length; i++) {
    var isin = String(isins[i][0]).replace(/[^A-Z0-9]/gi, '').trim().toUpperCase();
    
    if (isin && moexCache[isin]) {
      var bondInfo = moexCache[isin];
      
      // Читаем параметры из таблицы или падаем на дефолты из кэша
      var frequency = Number(sheet.getRange(i + 2, 10).getValue()) || bondInfo.period || 2;
      var faceValue = Number(sheet.getRange(i + 2, 14).getValue()) || bondInfo.faceValue || 1000;
      var couponValue = Number(sheet.getRange(i + 2, 16).getValue()) || bondInfo.couponValue || 0;
      var maturityStr = bondInfo.maturity;
      
      // Считаем точную внутреннюю норму доходности (XIRR/YTM)
      var calculatedYtm = calculateExactYTM(bondInfo.price, faceValue, bondInfo.nkd, couponValue, frequency, maturityStr);
      var ytmPercent = calculatedYtm * 100;
      
      priceData.push([bondInfo.price]);
      nkdData.push([bondInfo.nkd]);
      ytmData.push([ytmPercent / 100]); // Записываем в долях, Google Sheets сам отформатирует как %
    } else {
      // Если бумаги нет в кэше, оставляем старые или нулевые значения
      priceData.push([0]);
      nkdData.push([0]);
      ytmData.push([0]);
    }
  }
  
  // Быстрая пакетная запись в соответствующие столбцы таблицы
  // Предполагаем стандартную структуру: цены, НКД и YTM имеют свои колонки (настройте буквы под себя при необходимости)
  // Для безопасности пишем в фиксированные места (например: Цена в столбец K, НКД в L, YTM в P)
  sheet.getRange("K2:K" + lastRow).setValues(priceData).setNumberFormat('0.00"%"');
  sheet.getRange("L2:L" + lastRow).setValues(nkdData).setNumberFormat('#,##0.00');
  sheet.getRange("P2:P" + lastRow).setValues(ytmData).setNumberFormat('0.00%');
  
  SpreadsheetApp.flush();
}

// ============================================================
// БЛОК 5. АВТОМАТИЧЕСКИЙ СДВИГ ДАТ ПРОШЕДШИХ КУПОНОВ И ЗАЩИТА ОТ NaN
// ============================================================

function autoUpdateCouponDates() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Облигации");
  if (!sheet) return;
  
  var lastRow = sheet.getLastRow();
  if (lastRow < 2) return;
  
  var today = new Date();
  today.setHours(0, 0, 0, 0);
  
  // Пакетное считывание данных для производительности
  var couponRange = sheet.getRange("M2:M" + lastRow);
  var data = sheet.getRange("A2:M" + lastRow).getDisplayValues(); 
  
  var outputDates = [];
  var updated = false;
  
  for (var i = 0; i < data.length; i++) {
    var rawCouponDate = data[i][12]; // Столбец M
    var rawMaturity = data[i][6];    // Столбец G
    var frequency = parseInt(data[i][9]) || 0; // Столбец J
    
    // Проверка на NaN и валидность данных
    if (!rawCouponDate || rawCouponDate.indexOf("NaN") !== -1 || frequency <= 0) {
      outputDates.push([rawCouponDate]);
      continue;
    }
    
    var couponDate = parseDateLocal(rawCouponDate);
    var maturityDate = parseDateLocal(rawMaturity);
    
    if (couponDate && couponDate <= today) {
      // Расчет новой даты купона
      var monthsStep = 12 / frequency;
      couponDate.setMonth(couponDate.getMonth() + Math.ceil((today - couponDate) / (1000 * 60 * 60 * 24 * 30.4 * (12/frequency))) * monthsStep);
      
      // Защита: дата купона не может быть позже даты погашения
      if (maturityDate && couponDate > maturityDate) { 
        couponDate = maturityDate; 
      }
      
      outputDates.push([Utilities.formatDate(couponDate, Session.getScriptZone(), "dd.MM.yyyy")]);
      updated = true;
    } else {
      outputDates.push([rawCouponDate]);
    }
  }
  
  // Быстрая запись обновлений
  if (updated) {
    couponRange.setNumberFormat("@");
    couponRange.setValues(outputDates);
    SpreadsheetApp.flush();
  }
}

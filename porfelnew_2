/**
 * Загружает рыночные данные (Цены, НКД, Купоны) по ВСЕМ облигациям на бирже за 2 быстрых запроса
 * @return {Object} Кэш данных в формате { ISIN: { price, cpn, nkd, cpnPeriod, maturity } }
 */
function fetchAllMoexDataBatch() {
  var moexCache = {};
  var boards = ["TQOB", "TQCB"]; // TQOB - ОФЗ, TQCB - Корпоративные облигации
  
  for (var b = 0; b < boards.length; b++) {
    var board = boards[b];
    // Запрашиваем таблицы marketdata (цены) и securities (параметры бумаг) одновременно
    var url = "https://moex.com" + board + "/securities.json?iss.meta=off&iss.only=securities,marketdata";
    
    try {
      var response = UrlFetchApp.fetch(url, {muteHttpExceptions: true});
      if (response.getResponseCode() !== 200) continue;
      
      var json = JSON.parse(response.getContentText());
      if (!json) continue;
      
      // 1. Парсим статические параметры (Купоны, НКД, Базовые данные)
      var secData = json.securities;
      if (secData && secData.data) {
        var secCols = secData.columns;
        var isinIdx = secCols.indexOf("ISIN");
        var cpnPercentIdx = secCols.indexOf("COUPONPERCENT");
        var cpnValueIdx = secCols.indexOf("COUPONVALUE");
        var nkdIdx = secCols.indexOf("ACCRUEDINT");
        var periodIdx = secCols.indexOf("COUPONPERIOD");
        var matIdx = secCols.indexOf("MATDATE");
        var faceIdx = secCols.indexOf("FACEVALUE");
        
        for (var i = 0; i < secData.data.length; i++) {
          var row = secData.data[i];
          var isin = String(row[isinIdx]).trim().toUpperCase();
          if (!isin) continue;
          
          moexCache[isin] = {
            price: 0,
            couponPercent: parseFloat(row[cpnPercentIdx]) || 0,
            couponValue: parseFloat(row[cpnValueIdx]) || 0,
            nkd: parseFloat(row[nkdIdx]) || 0,
            period: parseInt(row[periodIdx], 10) || 0,
            maturity: row[matIdx] ? String(row[matIdx]).trim() : "",
            faceValue: parseFloat(row[faceIdx]) || 1000
          };
        }
      }
      
      // 2. Парсим динамические рыночные цены (LAST, LCURRENTPRICE)
      var marketData = json.marketdata;
      if (marketData && marketData.data) {
        var mCols = marketData.columns;
        var mIsinIdx = mCols.indexOf("SECID"); // В marketdata ISIN лежит в SECID
        var lastIdx = mCols.indexOf("LAST");
        var currIdx = mCols.indexOf("LCURRENTPRICE");
        var marketIdx = mCols.indexOf("MARKETPRICE");
        
        for (var j = 0; j < marketData.data.length; j++) {
          var mRow = marketData.data[j];
          var mIsin = String(mRow[mIsinIdx]).trim().toUpperCase();
          if (!moexCache[mIsin]) continue;
          
          var lastPrice = parseFloat(mRow[lastIdx]);
          var currPrice = parseFloat(mRow[currIdx]);
          var marketPrice = parseFloat(mRow[marketIdx]);
          
          // Выбираем приоритетную ненулевую цену
          var validPrice = lastPrice || currPrice || marketPrice || 0;
          if (validPrice > 0) {
            moexCache[mIsin].price = validPrice;
          }
        }
      }
    } catch(e) {
      Logger.log("Ошибка пакетной загрузки для режима " + board + ": " + e.message);
    }
  }
  return moexCache;
}


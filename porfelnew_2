/**
 * Создает автоматический триггер для запуска обновления каждый день в нерабочее время (20:00 - 21:00)
 */
function setupDailyAutomatedTriggers() {
  var triggerName = 'startUniqueBondCalendarGeneration2026';
  var triggers = ScriptApp.getProjectTriggers();
  
  // Удаляем старые дубликаты триггеров, если они есть
  for (var i = 0; i < triggers.length; i++) {
    if (triggers[i].getHandlerFunction() === triggerName) {
      ScriptApp.deleteTrigger(triggers[i]);
    }
  }
  
  // Создаем новый ежедневный триггер
  ScriptApp.newTrigger(triggerName)
    .timeBased()
    .everyDays(1)
    .atHour(20)
    .create();
    
  SpreadsheetApp.getUi().alert("⏰ Автоматизация включена! Скрипт будет обновлять цены и календарь каждый день между 20:00 и 21:00 по МСК.");
}


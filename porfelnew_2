// БЛОК 7. ЧАСТЬ 3: ГЕНЕРАЦИЯ ОПИСАНИЙ И ЗАПИСЬ СОБЫТИЯ В КАЛЕНДАРЬ
// ============================================================================

function writeSingleEventToCalendar(cal, title, eventDate, name, isin, cleanSum, signal, count) {
  var actionPlan = "";
  
  // Подбираем текстовый план действий на основе рыночного сигнала YTM
  if (signal.indexOf("🚨") !== -1) {
    actionPlan = "💡 АНАЛИТИКА БКС:\n⚠ Бумага перегрета, доходность упала. Рекомендуется ПРОДАТЬ выпуск в приложении БКС и зафиксировать прибыль.";
  } else if (signal.indexOf("🔥") !== -1) {
    actionPlan = "💡 АНАЛИТИКА БКС:\n📈 Высокая доходность! Цена занижена. Рекомендуется ИСПОЛЬЗОВАТЬ поступающие купоны для ДОКУПКИ этого выпуска.";
  } else {
    actionPlan = "💡 АНАЛИТИКА БКС:\n🟢 Стабильный плановый доход. Купоны отправляем на плановое реинвестирование.";
  }
  
  // Формируем красивую карточку описания
  var description = "📋 СВОДКА ПО ВЫПЛАТЕ:\n" +
                    "• Облигация: " + name + "\n" +
                    "• Код ISIN: " + isin + "\n" +
                    "• Сумма чистыми: " + cleanSum + " ₽\n" +
                    "• Статус YTM: " + signal + "\n\n" +
                    "----------------------------------------\n" +
                    actionPlan;
                    
  try {
    // Записываем событие в Google Календарь на весь день
    cal.createEvent(title, eventDate, eventDate, {description: description});
    count++;
  } catch(e) {
    Logger.log("Ошибка записи события: " + e.toString());
  }
  
  return count;
}

